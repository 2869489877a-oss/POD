# 本地 worker 主动拉取 POD 图片处理任务
# 复制为 local-worker.env 后填写。不要提交 local-worker.env。
# worker 会依次读取 .env.local、local-worker.env、.env；已存在的进程环境变量优先，不会被文件覆盖。

# POD 主系统地址。两套变量名均可：优先读取 LOCAL_WORKER_BASE_URL/POD_AI_BASE_URL，POD_API_URL 为 README 兼容名。
POD_API_URL=http://127.0.0.1:3000

# 必须与 POD 主系统环境变量 LOCAL_WORKER_SECRET 保持一致。
LOCAL_WORKER_SECRET=

# 本机 worker 名称，方便日志识别。
LOCAL_WORKER_ID=bruce-local-worker

# 支持的任务类型。两套变量名均可：优先读取 LOCAL_IMAGE_WORKER_JOB_TYPES，LOCAL_WORKER_JOB_TYPES 为 README 兼容名。
LOCAL_WORKER_JOB_TYPES=cutout,print_extraction,mockup,resize,fission,infringement_check

# 没有任务时的轮询间隔。两套变量名均可：优先读取 LOCAL_IMAGE_WORKER_POLL_MS（毫秒），POLL_INTERVAL_SECONDS 为 README 兼容名（秒）。
POLL_INTERVAL_SECONDS=5

# 本地请求和下载超时，单位秒；默认 30。
LOCAL_WORKER_REQUEST_TIMEOUT_SECONDS=120

# 单张输入图片下载和本地读取上限，单位 MB；默认 25。
LOCAL_WORKER_MAX_IMAGE_SIZE_MB=50

# rembg 默认模型。
LOCAL_REMBG_MODEL=isnet-general-use

# OpenCV 印花提取容差，越大越容易保留更多图案。
LOCAL_PRINT_TOLERANCE=25
