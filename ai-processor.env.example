# AI 智能处理配置
# 复制为 ai-processor.env 并填写 API Key

# ===== Step 1: AI 识图（通义千问 VL）=====
QWEN_VL_API_KEY=
QWEN_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-max

# ===== Step 4: AI 生图润色 =====
# 选择 provider: tongyi 或 doubao
AI_IMAGE_PROVIDER=tongyi

# 通义万相配置（如果 provider=tongyi）
# 默认复用 QWEN_VL_API_KEY，也可单独配置
TONGYI_IMAGE_API_KEY=
TONGYI_IMAGE_BASE_URL=https://dashscope.aliyuncs.com
TONGYI_IMAGE_MODEL=wanx-v1

# 豆包配置（如果 provider=doubao）
DOUBAO_IMAGE_API_KEY=
DOUBAO_IMAGE_BASE_URL=
DOUBAO_IMAGE_MODEL=

# ===== 通用配置 =====
# 最大重试次数
AI_MAX_RETRIES=2
